# bilibili-copywriter 配置（复制为 config.env 后修改本机路径）

# conda Python 路径（用于 whisper）
PYTHON_PATH=/path/to/your/conda/env/python.exe

# ffmpeg 路径
FFMPEG_PATH=/path/to/your/conda/env/Library/bin/ffmpeg.exe

# whisper 模块路径（加入 PATH 以找到依赖）
WHISPER_BIN_PATH=/path/to/your/conda/env/Library/bin

# SSL 证书路径（解决 SSL 问题）
SSL_CERT_FILE=/path/to/your/conda/env/lib/site-packages/certifi/cacert.pem

# 默认输出目录（相对于项目目录）
DEFAULT_OUTPUT_DIR=output

# whisper 模型大小: tiny, base, small, medium, large, turbo
WHISPER_MODEL=turbo

# whisper 设备: cuda 或 cpu
WHISPER_DEVICE=cuda
